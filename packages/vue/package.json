{
  "name": "@zeedhi/zd-signature-input-vue",
  "version": "1.0.1",
  "description": "Componente Vue/Vuetify Zeedhi para coleta de assinatura desenhada ou enviada por imagem.",
  "author": "Marcelo Teixeira <marcelo.teixeira@teknisa.com>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MATTecno/zd-signature-input.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/MATTecno/zd-signature-input/issues"
  },
  "homepage": "https://github.com/MATTecno/zd-signature-input#readme",
  "keywords": [
    "zeedhi",
    "vue",
    "vuetify",
    "signature",
    "assinatura",
    "canvas"
  ],
  "main": "dist/signature-input-vue.umd.js",
  "module": "dist/signature-input-vue.common.js",
  "types": "types/index.d.ts",
  "typings": "types/index.d.ts",
  "files": [
    "dist",
    "types",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "ZD_SIGNATURE_LIB_BUILD=true vue-cli-service build --target lib --name signature-input-vue --dest dist src/index.ts && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir types && node ../../scripts/fix-vue-types.js",
    "lint": "eslint src --ext .ts,.vue"
  },
  "dependencies": {
    "@zeedhi/zd-signature-input-common": "^1.0.1",
    "signature_pad": "^5.1.3"
  },
  "peerDependencies": {
    "@zeedhi/vuetify": "^1.120.0",
    "vue": "^2.7.6",
    "vue-class-component": "^7.2.6",
    "vue-property-decorator": "^9.1.2"
  }
}
